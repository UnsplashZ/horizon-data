{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "覆盖窗口的默认能力",
  "windows": ["main", "controls"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-hide",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:event:default",
    "global-shortcut:default"
  ]
}
