{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "horizon-data",
  "version": "0.1.6",
  "identifier": "com.horizondata.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html?view=main",
        "title": "horizon-data",
        "width": 800,
        "height": 200,
        "minWidth": 600,
        "minHeight": 150,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "visible": true
      },
      {
        "label": "settings",
        "url": "index.html?view=settings",
        "title": "horizon-data settings",
        "width": 290,
        "height": 510,
        "minWidth": 250,
        "minHeight": 400,
        "maxHeight": 800,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
