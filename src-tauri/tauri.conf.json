{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "horizon-data",
  "version": "0.1.0",
  "identifier": "com.horizondata.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html?view=main",
        "title": "horizon-data",
        "width": 520,
        "height": 150,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": true
      },
      {
        "label": "inputs",
        "url": "index.html?view=inputs",
        "title": "horizon-data inputs",
        "width": 230,
        "height": 150,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "grip",
        "url": "index.html?view=grip",
        "title": "horizon-data grip",
        "width": 190,
        "height": 170,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "gforce",
        "url": "index.html?view=gforce",
        "title": "horizon-data gforce",
        "width": 170,
        "height": 200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "settings",
        "url": "index.html?view=settings",
        "title": "horizon-data settings",
        "width": 280,
        "height": 460,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
