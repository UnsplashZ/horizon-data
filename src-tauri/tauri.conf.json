{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "horizon-data",
  "version": "0.1.12",
  "identifier": "com.horizondata.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html?view=main",
        "title": "horizon-data",
        "width": 660,
        "height": 204,
        "minWidth": 480,
        "minHeight": 148,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "visible": true
      },
      {
        "label": "controls",
        "url": "index.html?view=controls",
        "title": "horizon-data controls",
        "width": 360,
        "height": 500,
        "minWidth": 340,
        "minHeight": 500,
        "maxWidth": 420,
        "maxHeight": 560,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
